// Prisma schema for Bolão Copa 2026

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── NextAuth Tables ──

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Domain Tables ──

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  bets             Bet[]
  bolaoMemberships BolaoMember[]
  boloes           Bolao[]       @relation("BolaoOwner")

  @@map("users")
}

model Bolao {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation("BolaoOwner", fields: [ownerId], references: [id])

  members BolaoMember[]
  bets    Bet[]

  @@map("boloes")
}

model BolaoMember {
  id       String @id @default(cuid())
  role     String @default("member") // "admin" | "member"

  bolaoId String
  bolao   Bolao @relation(fields: [bolaoId], references: [id], onDelete: Cascade)

  userId String
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bolaoId, userId])
  @@map("bolao_members")
}

model Match {
  id          String    @id @default(cuid())
  homeTeam    String
  awayTeam    String
  groupName   String?
  round       Int       @default(1) // 1=groups, 2=round32, 3=round16, 4=quarter, 5=semi, 6=third, 7=final
  matchNumber Int
  date        DateTime
  location    String?

  homeScore Int?
  awayScore Int?
  finished  Boolean @default(false)
  started   Boolean @default(false)

  createdAt DateTime @default(now())

  bets Bet[]

  @@map("matches")
}

model Bet {
  id        String   @id @default(cuid())
  homeScore Int
  awayScore Int
  points    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  bolaoId String
  bolao   Bolao  @relation(fields: [bolaoId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId, bolaoId])
  @@map("bets")
}
